# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
HTTPS=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# For acceptance/production, use:
# DEBUG=False
# HTTPS=True
# ALLOWED_HOSTS=yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Database
# SQLite (default for local development):
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (for acceptance/production — see documentation/deployment.md):
# DATABASE_URL=postgres://cmpng:password@localhost/cmpng

# Google APIs (required for geocoding and maps)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Location settings
DEPARTURE_CENTER=Geldermalsen, Gelderland, Netherlands

# Site identity
SITE_NAME=Vakantieplanner
META_DESCRIPTION=A Django app for managing and sharing travel plans, locations and experiences.

# Email (optional)
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
