# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# SQLite (default for local development):
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (for acceptance/production — see documentation/deployment.md):
# DATABASE_URL=postgres://cmpng:password@localhost/cmpng

# Google APIs (required for geocoding and maps)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Location settings
DEPARTURE_CENTER=Geldermalsen, Gelderland, Netherlands

# Email (optional)
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
