"{{ location.slug }}": {
  "id": "{{ location.id }}",
  "name": "{{ location.name }}",
  "summary": "{{ location.summary|default:'' }}",
  "url": "{{ location.get_absolute_url }}",
  "coord_lat": {{ location.coord_lat|default:'0' }},
  "coord_lon": {{ location.coord_lon|default:'0' }},
  "nearby_distance": {{ location.nearby_distance|default:'0' }},
  "is_accommodation": {{ location.is_accommodation|lower }},
  "is_activity": {{ location.is_activity|lower }},
  "visited": {% if user in location.visitors.all %}true{% else %}false{% endif %},
  "loved": {% if user.preferences in location.favorited.all %}true{% else %}false{% endif %}
}